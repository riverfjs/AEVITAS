{
  "agent": {
    "workspace": "~/.aevitas/workspace",
    "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "deepseek-ai/DeepSeek-V3"
        ]
      },
    "maxTokens": 8192,
    "temperature": 0.7,
    "maxToolIterations": 100,
    "historyLimit": 30,
    "autoRecall": true,
    "toolLog": {
      "enabled": false,
      "interval": 5
    },
    "compaction": {
      "enabled": false,
      "threshold": 0.8
    },
    "contextWindow": {
      "tokens": 0,
      "warnRatio": 0.8,
      "hardMinTokens": 2000
    },
    "memoryFlush": {
      "enabled": true,
      "reserveTokensFloor": 20000,
      "softThresholdTokens": 4000
    },
    "tokenTracking": {
      "enabled": true
    },
    "guard": {
      "inputEnabled": true,
      "outputEnabled": true
    }
  },
  "provider": {
    "type": "anthropic",
    "apiKey": "${ANTHROPIC_API_KEY}",
    "baseUrl": ""
  },
  "voice": {
    "enabled": false,
    "asr": {
      "enabled": false,
      "provider": "assemblyai",
      "apiKey": "${ASSEMBLYAI_API_KEY}",
      "baseUrl": "https://api.assemblyai.com",
      "speechModels": ["universal-3-pro", "universal-2"],
      "languageDetection": true,
      "pollIntervalSec": 3,
      "timeoutSec": 120
    },
    "tts": {
      "enabled": false,
      "provider": "edge",
      "voice": "zh-CN-XiaoxiaoNeural",
      "rate": "+0%",
      "volume": "+0%",
      "pitch": "+0Hz",
      "outputDir": "",
      "timeoutSec": 60
    }
  },
  "tools": {
    "braveApiKey": "${BRAVE_API_KEY}",
    "execTimeout": 60,
    "restrictToWorkspace": true
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [],
      "proxy": ""
    },
    "feishu": {
      "enabled": false,
      "appId": "",
      "appSecret": "",
      "verificationToken": "",
      "encryptKey": "",
      "port": 8080,
      "allowFrom": []
    },
    "wecom": {
      "enabled": false,
      "token": "",
      "encodingAESKey": "",
      "receiveId": "",
      "port": 8081,
      "allowFrom": []
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  }
}
